{
  "name": "chat-state-convex",
  "version": "0.5.0",
  "description": "Convex state adapter for @vercel/chat",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "import": "./dist/component/convex.config.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "npm run build:component && npm run build:pkg",
    "build:component": "npx convex codegen --component-dir src/component",
    "build:pkg": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "convex": "^1.34.0"
  },
  "peerDependencies": {
    "chat": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "chat": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "chat": "^4.23.0",
    "convex-test": "^0.0.41",
    "tsup": "^8.3.5",
    "typescript": "~5.7.0",
    "vitest": "^4.0.0"
  }
}
